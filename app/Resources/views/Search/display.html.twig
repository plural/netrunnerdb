{% extends '/layout.html.twig' %}

{% block title %}{{ title }}{% endblock %}

{% block body %}
<div class="container">

<p>Try the <a href="{{ path('cards_find_v3') }}">✨✨✨ New Search ✨✨✨</a> for more powerful search options and faster searches.</p>

{{ searchbar|raw }}

<div id="list">

{{ pagination|raw }}

{% if cards|length > 0 %}

{% block main %}{% endblock %}

{% else %}

<div class="col-sm-12" style="margin-top:10px">
